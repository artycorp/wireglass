{
  "version": 1,
  "schemas": [
    {
      "id": "server-response-required-id",
      "name": "Server response requires id",
      "pattern": "/",
      "target": "response",
      "schema": {
        "type": "object",
        "required": ["id"]
      }
    }
  ],
  "dashboards": [
    {
      "id": "server-grafana-local",
      "name": "Server Grafana",
